{
  "$schema": "https://raw.githubusercontent.com/nicoverali/tauri-v2-json-schema/refs/tags/latest/tauri.conf.schema.json",
  "productName": "SmartCrab",
  "version": "0.1.4",
  "identifier": "ai.smartcrab.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "SmartCrab",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ]
  }
}